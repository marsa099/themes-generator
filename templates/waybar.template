* {
  font-family: "Roboto", "JetBrainsMono NF", monospace;
  font-size: 16px;
  min-height: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  color: {{foreground.primary}};
}

window#waybar {
  background: transparent;
  background-color: rgba(0, 0, 0, 0);
}

/* Left side modules */
.modules-left {
  background: transparent;
  margin: 8px;
  padding: 0;
}

#hardware {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 0px 8px;
}

#custom-devops {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 6px 12px;
  margin-left: 12px;
  font-weight: 500;
}

#custom-devops.empty {
  background: transparent;
  padding: 0;
  margin: 0;
  min-width: 0;
}

#custom-devops.stale {
  opacity: 0.5;
}

#custom-devops.building {
  color: {{accent.yellow}};
}

#custom-devops.build-failed {
  color: {{accent.red}};
}

#custom-devops.build-succeeded {
  color: {{accent.green}};
}

#custom-devops.releasing {
  color: {{accent.yellow}};
}

#custom-devops.release-succeeded {
  color: {{accent.green}};
}

#custom-devops.release-failed {
  color: {{accent.red}};
}

#cpu,
#memory {
  padding: 6px 12px;
  margin: 0;
  background: transparent;
  color: {{foreground.primary}};
  border-radius: 0;
}

#custom-cpu-temp {
  padding: 6px 0 6px 12px;
  margin: 0;
  background: transparent;
  color: {{foreground.primary}};
  border-radius: 0;
}

#custom-gpu-temp {
  padding: 6px 12px 6px 0;
  margin: 0;
  background: transparent;
  color: {{foreground.primary}};
  border-radius: 0;
}

#cpu.medium,
#memory.medium {
  color: {{accent.yellow}};
}

#cpu.elevated,
#memory.elevated {
  color: {{accent.orange}};
}

#cpu.critical,
#memory.critical {
  color: {{accent.red}};
}

#clock.date,
.modules-left #custom-weather {
  padding: 6px 12px;
  margin: 0;
  background: transparent;
  color: {{foreground.primary}};
  border-radius: 0;
}

.modules-left #custom-weather {
  color: {{accent.cyan}};
}

/* Center module */
.modules-center {
  background: transparent;
  margin: 8px;
  padding: 0;
}

#workspaces {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 0px 8px;
}

#workspaces button {
  padding: 6px 8px;
  margin: 4px 2px;
  background: transparent;
  color: alpha({{foreground.primary}}, 0.15);
  border-radius: 6px;
  opacity: 0.3;
  font-size: 12px;
  transition: all 0.3s ease;
}

#workspaces button label {
  font-size: inherit;
}

#workspaces button.active {
  color: {{foreground.primary}};
  opacity: 1;
}

#custom-niri-minimap {
  padding: 0 12px;
  margin: 0;
  background: transparent;
  border-radius: 0;
  font-size: 16px;
}

#custom-dnd.active {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 6px 16px;
  margin-left: 12px;
  color: {{accent.rose}};
  font-size: 16px;
}

#custom-dnd.inactive {
  padding: 0;
  margin: 0;
  min-width: 0;
}

#custom-discord-notifications,
#custom-teams-notifications {
  padding: 6px 12px;
  margin: 0;
  background: transparent;
  color: #5865F2;
  border-radius: 0;
  font-size: 16px;
}

#custom-discord-notifications.empty,
#custom-teams-notifications.empty {
  padding: 0;
  margin: 0;
  min-width: 0;
}

/* Right side container */
.modules-right {
  background: transparent;
  margin: 8px;
  padding: 0;
}

/* Content Delivery → IdP status dots. Its own standalone pill in modules-left
   (like #custom-devops), so there's a real transparent gap before it instead
   of being fused into the hardware pill. The dot colors are inline pango,
   set by waybar-idp-status. */
#custom-idp-status {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 6px 12px;
  margin-left: 12px;
}

/* Currently-focused Claude session name. Hidden when the focused window
   isn't a Claude session. .busy turns it orange; .remote tints it cyan. */
#custom-claude-focused {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 6px 14px;
  margin-right: 12px;
  font-weight: 500;
  color: {{foreground.secondary}};
}

#custom-claude-focused.remote {
  color: {{accent.cyan}};
}

#custom-claude-focused.busy {
  color: {{accent.orange}};
}

/* Currently-focused Helium browser profile. Hidden when the focused window
   isn't Helium. Tinted per profile to match each profile's identity colour. */
#custom-helium-focused {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 6px 14px;
  margin-right: 12px;
  font-weight: 500;
  color: {{foreground.secondary}};
}

#custom-helium-focused.sis      { color: {{accent.blue}}; }
#custom-helium-focused.sisadmin { color: {{accent.red}}; }
#custom-helium-focused.koderiet { color: {{accent.green}}; }
#custom-helium-focused.regent   { color: {{accent.rose}}; }
#custom-helium-focused.private  { color: {{accent.cyan}}; }

#custom-claude-cost {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 6px 14px;
  margin-right: 12px;
  font-weight: 500;
  color: {{accent.green}};
}

#custom-claude-cost.medium {
  color: {{accent.yellow}};
}

#custom-claude-cost.high {
  color: {{accent.red}};
}

/* Claude waiting indicator — pill matches the other tray modules; orange to
   signal an un-acknowledged Claude prompt. Hidden when nothing is pending. */
#custom-claude-pending {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 6px 14px;
  margin-right: 12px;
  font-weight: 500;
  color: {{accent.orange}};
}

#tray {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 0px 12px;
  margin-right: 12px;
}

#tray > .passive {
  -gtk-icon-effect: dim;
}

#tray > .needs-attention {
  -gtk-icon-effect: highlight;
}

#system {
  background: alpha({{background.secondary}}, 0.95);
  border-radius: 8px;
  padding: 0px 8px;
}

#clock,
#battery,
#network,
#bluetooth,
#custom-language,
#pulseaudio {
  padding: 6px 10px;
  margin: 0;
  background: transparent;
  color: {{foreground.primary}};
  border-radius: 0;
}

#battery {
  padding-left: 14px;
}

#battery.warning {
  color: {{accent.yellow}};
}

#battery.critical {
  color: {{accent.red}};
}

#battery.charging {
  color: {{foreground.primary}};
}

#clock {
  color: {{foreground.primary}};
}

#network.disconnected {
  color: {{accent.red}};
}

#pulseaudio {
  color: {{accent.blue}};
}

#pulseaudio.muted {
  color: {{accent.cyan}};
}

tooltip {
  background: alpha({{background.secondary}}, 0.95);
  border: 1px solid alpha({{accent.cyan}}, 0.2);
  border-radius: 8px;
}

tooltip label {
  color: {{foreground.primary}};
}

menu {
  background: {{background.secondary}};
  border: 1px solid alpha({{accent.cyan}}, 0.2);
  border-radius: 8px;
}

menu menuitem {
  color: {{foreground.primary}};
}

menu menuitem:hover {
  background: alpha({{foreground.primary}}, 0.1);
}
